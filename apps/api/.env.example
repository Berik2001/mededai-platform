NODE_ENV=development
API_PORT=4000

DATABASE_URL="postgresql://med:medpass@localhost:5432/med_platform?schema=public"
MONGODB_URI="mongodb://med:medpass@localhost:27017/med_content?authSource=admin"

# ─── Auth (JWT access + refresh) ─────────────────────────────────
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_DAYS="7"

# ─── Gemini (Google Generative Language API) ─────────────────────
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ─── Security ────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
CORS_ORIGINS="http://localhost:3000"
# Reject non-HTTPS requests (defaults to true when NODE_ENV=production)
FORCE_HTTPS=false

# ─── Audit ───────────────────────────────────────────────────────
AUDIT_ENABLED=true

# ─── Backups (scheduled pg_dump) ─────────────────────────────────
BACKUP_ENABLED=false
BACKUP_DIR="./backups"
BACKUP_RETENTION_DAYS=7
# Cron expression (default: daily at 03:00)
BACKUP_CRON="0 3 * * *"
