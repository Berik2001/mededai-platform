# ═══════════════════════════════════════════════════════════════════
# AI Medical Education Platform — environment configuration
# Copy to `.env` (`cp .env.example .env`) and adjust. docker compose reads
# this file automatically; for local (non-Docker) dev see apps/api/.env.example.
# ═══════════════════════════════════════════════════════════════════

# ─── PostgreSQL (relational core: users, sessions, audit, OSCE, …) ──
POSTGRES_USER=med
POSTGRES_PASSWORD=medpass
POSTGRES_DB=med_platform
POSTGRES_PORT=5432

# ─── MongoDB (flexible content: clinical cases, virtual-patient state) ──
MONGO_USER=med
MONGO_PASSWORD=medpass
MONGO_DB=med_content
MONGO_PORT=27017

# ─── Auth (JWT access + rotating refresh tokens) ────────────────────
# MUST be a long random string in production, e.g. `openssl rand -hex 48`.
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m       # short-lived access token
JWT_REFRESH_EXPIRES_DAYS=7      # refresh-token lifetime (rotated on every use)

# ─── Gemini (Google Generative Language API) ────────────────────────
# Optional: every AI feature has a deterministic fallback when this is blank,
# so the platform is fully usable without a key (no live AI generation).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Security ───────────────────────────────────────────────────────
# Comma-separated allowed CORS origins (the public web origin behind nginx).
CORS_ORIGINS=https://localhost
# Reject non-TLS API requests. Behind nginx (which sets X-Forwarded-Proto)
# you may set this to true in production. Left false so internal healthchecks pass.
FORCE_HTTPS=false

# ─── Audit log ──────────────────────────────────────────────────────
AUDIT_ENABLED=true

# ─── Backups (scheduled pg_dump; managed from the Admin panel) ──────
BACKUP_ENABLED=false
BACKUP_RETENTION_DAYS=7
BACKUP_CRON=0 3 * * *           # daily at 03:00

# ─── Web (Next.js) ──────────────────────────────────────────────────
# Empty → the browser calls "/api" on the same origin (correct behind nginx).
# For local dev without nginx, set http://localhost:4000.
NEXT_PUBLIC_API_URL=

# ─── nginx reverse proxy (host ports) ───────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
